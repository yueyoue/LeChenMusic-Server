# 服务配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# 数据库
DB_TYPE=sqlite
DB_PATH=./data/lechen.db

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=30d

# 转码
MAX_TRANSCODE_TASKS=4
TRANSCODE_CACHE_DIR=./data/transcode-cache
TRANSCODE_CACHE_MAX_SIZE_MB=2048

# 日志
LOG_LEVEL=info

# CORS（逗号分隔，留空允许所有）
CORS_ORIGINS=
